# Bridge configuration. Copy to .env or run ./deploy.sh.
# All variables are required unless marked optional. Validation rules in app/config.py.

# ── Identifiers ──────────────────────────────────────────────────────────────
# DDL identifier prefix; regex ^[a-z][a-z0-9_]{0,30}$
TABLE_PREFIX=silo_farm_a

# ── InfluxDB 2.x ─────────────────────────────────────────────────────────────
INFLUX_URL=http://10.0.0.10:8086
INFLUX_TOKEN=replace_with_real_token_min_16_chars
INFLUX_ORG=easyfoods
INFLUX_BUCKET=plant_metrics
INFLUX_MEASUREMENT=fill_level
INFLUX_FIELD=value

# Tag dimension. Each silo is a tag value; the bridge fans out across the allowlist.
# INFLUX_TAG_KEY is also the name of the MySQL column. Regex ^[a-z][a-z0-9_]{0,30}$
INFLUX_TAG_KEY=silo
INFLUX_TAG_VALUES=silo_1,silo_2,silo_3

# ── MySQL 8.4 ────────────────────────────────────────────────────────────────
MYSQL_HOST=10.0.0.20
MYSQL_PORT=3306
MYSQL_USER=bridge
MYSQL_PASSWORD=replace_with_real_password
MYSQL_DB=plant_data

# ── Polling ──────────────────────────────────────────────────────────────────
# QUERY_WINDOW_SECONDS must be >= 2 * POLL_INTERVAL_SECONDS.
POLL_INTERVAL_SECONDS=10
QUERY_WINDOW_SECONDS=20

# ── Google Apps Script (optional) ────────────────────────────────────────────
# If set, the bridge POSTs {"<tag>_level": <value>, ...} to this Google Script
# after every successful insert. Leave empty to disable.
GOOGLE_SCRIPT_TARGET_TOKEN=

# Set automatically by deploy.sh; do not edit by hand.
COMPOSE_PROJECT_NAME=silo_farm_a
